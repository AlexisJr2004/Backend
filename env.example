# ==========================================
#  Variables de entorno - CRUD Usuarios API
#  Copia este archivo como .env y completa los valores reales.
#  NO subas el archivo .env real al repositorio.
# ==========================================

# --- Base de datos (MongoDB Atlas) ---
# Reemplaza usuario, contraseña y el host por los de tu cluster.
# Incluye el nombre de la base de datos (crud_usuarios) antes del "?".
MONGO_URI=mongodb+srv://usuario:contraseña@cluster.xxxxx.mongodb.net/crud_usuarios?retryWrites=true&w=majority

# --- Autenticación JWT ---
# Clave secreta para firmar los tokens. Usa una cadena larga y difícil de adivinar.
JWT_SECRET=tu_clave_secreta_aqui

# --- Google OAuth 2.0 ---
# Credenciales obtenidas en Google Cloud Console.
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# URL de callback registrada en Google Cloud (debe coincidir exactamente).
# En local:   http://localhost:3000/api/auth/google/callback
# En Render:  https://tu-backend.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://tu-backend.onrender.com/api/auth/google/callback

# --- Front-End ---
# URL del front (para redirigir tras el login con Google).
# En local:   http://localhost:3000
# En Vercel:  https://tu-frontend.vercel.app
FRONTEND_URL=https://tu-frontend.vercel.app
